# Server Configuration
PORT=3000
NODE_ENV=development

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Queue Configuration
QUEUE_PREFIX=task-queue
DEFAULT_JOB_OPTIONS_REMOVE_ON_COMPLETE=100
DEFAULT_JOB_OPTIONS_REMOVE_ON_FAIL=50
DEFAULT_JOB_OPTIONS_ATTEMPTS=3
DEFAULT_JOB_OPTIONS_BACKOFF_TYPE=exponential
DEFAULT_JOB_OPTIONS_BACKOFF_DELAY=2000

# Worker Configuration
WORKER_CONCURRENCY=10
WORKER_MAX_STALL_TIME=30000

# Bull Board Configuration
BULL_BOARD_PATH=/admin/queues
BULL_BOARD_ENABLED=true
BULLBOARD_USERNAME=admin
BULLBOARD_PASSWORD=admin

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_ERROR_FILE=logs/error.log
